# ============================================================
# Sightline — .gitignore
# ============================================================

# ---- Node ----
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*
.npm/
.eslintcache

# ---- Vite / frontend build ----
dist/
dist-ssr/
.vite/
*.local
*.tsbuildinfo

# ---- Rust / Cargo ----
target/
**/*.rs.bk
Cargo.lock.bak

# ---- Tauri ----
src-tauri/target/
src-tauri/gen/
src-tauri/WixTools/
src-tauri/binaries/yt-dlp-*
src-tauri/binaries/ffmpeg-*
src-tauri/binaries/ffprobe-*

# ---- Environment / secrets ----
.env
.env.*
!.env.example
*.pem
*.key
*.cer
*.p12
.secrets/

# ---- IDE / OS ----
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.recommended.json
.DS_Store
Thumbs.db
ehthumbs.db

# ---- Claude Code ----
.claude/settings.local.json
CLAUDE.local.md

# ---- Logs / coverage / caches ----
*.log
logs/
coverage/
.nyc_output/
.turbo/
.cache/

# ---- Playwright ----
playwright-report/
test-results/
.playwright/

# ---- App data (should never land in repo) ----
*.sqlite
*.sqlite-journal
*.db
app-data/
